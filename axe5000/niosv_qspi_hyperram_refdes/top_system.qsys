          <ipxact:value>bonusData 
{
   element clock_in
   {
      datum _sortIndex
      {
         value = "0";
         type = "int";
      }
   }
   element clock_subsystem_0
   {
      datum _sortIndex
      {
         value = "1";
         type = "int";
      }
   }
   element mipi_system_0.vid_mm_bus
   {
      datum baseAddress
      {
         value = "0";
         type = "String";
      }
   }
   element niosv_system_0
   {
      datum _sortIndex
      {
         value = "2";
         type = "int";
      }
   }
   element sysA_0
   {
      datum _sortIndex
      {
         value = "3";
         type = "int";
      }
   }
}
